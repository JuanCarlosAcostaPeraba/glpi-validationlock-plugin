msgid "Validation Lock"
msgstr "Bloqueo por Validación"

msgid "Cannot resolve or close ticket while there are pending validations."
msgstr "No se puede resolver ni cerrar el ticket mientras existan validaciones pendientes."

msgid "Cannot add a solution while there are pending validations."
msgstr "No se puede añadir una solución mientras existan validaciones pendientes."
